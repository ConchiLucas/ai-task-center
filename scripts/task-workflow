#!/usr/bin/env python3
import argparse
import json
import os
import urllib.request


DEFAULT_BASE_URL = "http://127.0.0.1:18743"
DEFAULT_HTTP_TIMEOUT_SECONDS = 10.0
MAX_HTTP_TIMEOUT_SECONDS = 120.0
HEX_DIGITS = "0123456789abcdef"


class WorkflowError(Exception):
    pass


def non_empty(value):
    if not value or not value.strip():
        raise argparse.ArgumentTypeError("value must not be blank")
    return value


def positive_integer(value):
    try:
        number = int(value)
    except ValueError as error:
        raise argparse.ArgumentTypeError("must be a positive integer") from error
    if number <= 0:
        raise argparse.ArgumentTypeError("must be a positive integer")
    return number


def sha256(value):
    if len(value) != 64 or any(character not in HEX_DIGITS for character in value):
        raise argparse.ArgumentTypeError("must be a 64-character lowercase SHA-256 hash")
    return value


def entity_ids(value):
    parts = [part.strip() for part in value.split(",")]
    if not parts or any(not part for part in parts):
        raise argparse.ArgumentTypeError("entity IDs must be comma-separated positive integers")
    try:
        ids = [positive_integer(part) for part in parts]
    except argparse.ArgumentTypeError as error:
        raise argparse.ArgumentTypeError("entity IDs must be comma-separated positive integers") from error
    return ids


def validate_entity_ids(stage, ids):
    ids_to_check = ids if stage == "result" else ids[1:]
    if len(set(ids_to_check)) != len(ids_to_check):
        raise WorkflowError("Duplicate entity IDs are not allowed")


def http_timeout_seconds(value):
    try:
        timeout = float(value)
    except ValueError as error:
        raise WorkflowError("TASK_CENTER_HTTP_TIMEOUT_SECONDS must be a positive number") from error
    if not 0 < timeout <= MAX_HTTP_TIMEOUT_SECONDS:
        raise WorkflowError(
            "TASK_CENTER_HTTP_TIMEOUT_SECONDS must be greater than 0 and at most %d" % MAX_HTTP_TIMEOUT_SECONDS)
    return timeout


def redact(message, token):
    return str(message).replace(token, "[REDACTED]")


def backend_message(body):
    try:
        response = json.loads(body.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError):
        return None, None
    if not isinstance(response, dict):
        return None, None
    return response.get("code"), response.get("msg")


def post_report(base_url, task_config_id, payload, token, timeout_seconds):
    url = base_url.rstrip("/") + "/api/task/%d/onboarding/report" % task_config_id
    request = urllib.request.Request(
        url,
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout_seconds) as response:
            status = response.getcode()
            body = response.read()
    except Exception as error:
        body = error.read() if hasattr(error, "read") else b""
        _, message = backend_message(body)
        if message:
            raise WorkflowError(redact(message, token)) from None
        raise WorkflowError(redact("Connection error: %s" % error, token)) from None

    code, message = backend_message(body)
    if status < 200 or status >= 300:
        raise WorkflowError(redact(message or "Backend returned HTTP %d" % status, token))
    if code != 0:
        raise WorkflowError(redact(message or "Backend rejected the callback", token))


def build_parser():
    parser = argparse.ArgumentParser(
        description="Report task onboarding callback results.", allow_abbrev=False)
    subcommands = parser.add_subparsers(dest="command", required=True)
    report = subcommands.add_parser(
        "report", help="Submit an onboarding callback report.", allow_abbrev=False)
    report.add_argument("--task-config-id", required=True, type=positive_integer)
    report.add_argument("--stage", required=True, choices=("result", "batch"))
    report.add_argument("--token", required=True, type=non_empty)
    report.add_argument("--artifact", required=True, type=non_empty)
    report.add_argument("--artifact-hash", required=True, type=sha256)
    report.add_argument("--entity-ids", required=True, type=entity_ids)
    return parser


def main():
    parser = build_parser()
    arguments = parser.parse_args()
    base_url = os.environ.get("TASK_CENTER_BASE_URL", DEFAULT_BASE_URL).strip()
    if not base_url:
        parser.exit(1, "Error: TASK_CENTER_BASE_URL must not be blank\n")
    try:
        timeout_seconds = http_timeout_seconds(
            os.environ.get("TASK_CENTER_HTTP_TIMEOUT_SECONDS", str(DEFAULT_HTTP_TIMEOUT_SECONDS)).strip())
        validate_entity_ids(arguments.stage, arguments.entity_ids)
    except WorkflowError as error:
        parser.exit(1, "Error: %s\n" % redact(error, arguments.token))
    payload = {
        "stage": arguments.stage,
        "token": arguments.token,
        "artifact": arguments.artifact,
        "artifactHash": arguments.artifact_hash,
        "entityIds": arguments.entity_ids,
    }
    try:
        post_report(base_url, arguments.task_config_id, payload, arguments.token, timeout_seconds)
    except WorkflowError as error:
        parser.exit(1, "Error: %s\n" % redact(error, arguments.token))
    print("Onboarding report accepted.")


if __name__ == "__main__":
    main()
